# ───────────────────────────── mymusicdl ─────────────────────────────
# Copy to `.env` and fill in. In the homelab the compose file lives at
# /opt/stacks/mymusicdl/ and the data/music dirs resolve under /opt/dades.

# ── networking ──
PORT=8080
DOCKFLARE_ACCESS_GROUP=family

# ── data paths (host side, homelab convention; bind-mounted in compose) ──
#   data  → ../../dades/mymusicdl/data   (SQLite + toolsvenv)
#   music → ../../dades/mymusicdl/music  (== Navidrome's rclone→pCloud mount)
# Inside the container these are fixed: APP_DATA_DIR=/data, MUSIC_LIBRARY_PATH=/music
APP_DATA_DIR=/data
MUSIC_LIBRARY_PATH=/music
TOOLS_VENV=/data/toolsvenv

# ── Navidrome / Subsonic ──
# The client computes t=md5(password+salt), s=salt, v=1.16.1, c=mymusicdl, f=json
NAVIDROME_URL=http://navidrome:4533
NAVIDROME_USER=mymusicdl
NAVIDROME_PASSWORD=change-me

# ── Spotify metadata (free client-credentials; also what spotdl resolves against) ──
# Leave blank to fall back to MusicBrainz (no key needed).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── downloads ──
DOWNLOAD_CONCURRENCY=2
DEFAULT_FORMAT=mp3
DEFAULT_BITRATE=320k

# ── updater ──
VERSION_CHECK_INTERVAL_HOURS=24
# Optional: raises GitHub API rate limit for changelog fetches (60→5000/h)
GITHUB_TOKEN=

# ── security ──
# Encrypts provider credentials stored in the DB. Generate a long random string.
APP_SECRET=change-me-to-a-random-32+-char-string
# Optional fallback gate ON TOP of Cloudflare Access. Empty = rely solely on the edge.
APP_SHARED_PASSWORD=

# ── paid providers (leave blank to keep them DISABLED; fill later to enable streamrip/tiddl) ──
# TIDAL_TOKEN=
# QOBUZ_TOKEN=
# DEEZER_ARL=
