# ───────────────────────────── mymusicdl ─────────────────────────────
# Copy to `.env` and fill in, then `docker compose up -d`.

# ── web / edge ──
PORT=8080
# Hostname your reverse proxy / Cloudflare tunnel exposes the app on.
PUBLIC_HOSTNAME=music.example.com
# Dockflare/Cloudflare Access group allowed to reach it.
DOCKFLARE_ACCESS_GROUP=family
# Host IP to bind the web UI on. 127.0.0.1 = loopback only; use a LAN IP or 0.0.0.0
# to expose it directly (you can omit it entirely if you only reach it via the tunnel).
LAN_BIND_IP=127.0.0.1

# ── external networks & volumes (must already exist on the host) ──
# EDGE_NETWORK    = the network your Cloudflare tunnel / reverse proxy is on.
# INTERNAL_NETWORK= the shared network Navidrome and friends sit on.
# MUSIC_VOLUME    = the named volume holding the music library (the one Navidrome mounts).
EDGE_NETWORK=cloudflare-net
INTERNAL_NETWORK=internal
MUSIC_VOLUME=music

# ── data dir (host side; holds SQLite + the tools venv) ──
# Relative to the compose file, or an absolute path. The music library is NOT here —
# it lives in MUSIC_VOLUME above. Inside the container these are fixed.
DATA_DIR=./data
APP_DATA_DIR=/data
MUSIC_LIBRARY_PATH=/music
TOOLS_VENV=/data/toolsvenv

# ── Navidrome / Subsonic ──
# The client computes t=md5(password+salt), s=salt, v=1.16.1, c=mymusicdl, f=json
NAVIDROME_URL=http://navidrome:4533
NAVIDROME_USER=mymusicdl
NAVIDROME_PASSWORD=change-me

# ── Spotify metadata (free client-credentials; also what spotdl resolves against) ──
# Leave blank to fall back to MusicBrainz (no key needed).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── downloads ──
DOWNLOAD_CONCURRENCY=2
DEFAULT_FORMAT=mp3
DEFAULT_BITRATE=320k

# ── updater ──
VERSION_CHECK_INTERVAL_HOURS=24
# Optional: raises GitHub API rate limit for changelog fetches (60→5000/h)
GITHUB_TOKEN=

# ── security ──
# Encrypts provider + bot credentials stored in the DB. Generate a long random string.
APP_SECRET=change-me-to-a-random-32+-char-string
# Optional fallback gate ON TOP of Cloudflare Access. Empty = rely solely on the edge.
APP_SHARED_PASSWORD=

# ── messaging bots (optional) — same features as the web, over chat ───────────────
# Leave blank to keep a bot OFF, or configure it later in the Settings page (stored
# encrypted in the DB). Values here take precedence over the Settings page.
#
# Telegram: create a bot with @BotFather to get the token. TELEGRAM_ALLOWED_USERS is a
# comma-separated allowlist of numeric user IDs; only they can search/download. If empty,
# the bot replies to anyone with their own ID so you can add it here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
#
# Matrix (no E2E — use a dedicated unencrypted room). Invite the bot user; it auto-joins.
# MATRIX_ALLOWED_USERS is a comma-separated allowlist of @user:server IDs.
MATRIX_HOMESERVER=
MATRIX_USER_ID=
MATRIX_ACCESS_TOKEN=
MATRIX_ALLOWED_USERS=
# Optional: restrict the bot to a single room id (e.g. !abc:server). Empty = any joined room.
MATRIX_ROOM_ID=

# ── paid providers (leave blank to keep them DISABLED; fill later to enable streamrip/tiddl) ──
# TIDAL_TOKEN=
# QOBUZ_TOKEN=
# DEEZER_ARL=
